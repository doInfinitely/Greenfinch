# OpenAI API key (used by browser-use for LLM extraction)
OPENAI_API_KEY=sk-...

# Port to run the service on
PORT=8100

# Max concurrent browser instances
MAX_CONCURRENT=3

# Browser headless mode (set to false for debugging)
HEADLESS=true

# Directory for trajectory recordings (defaults to ./trajectories/)
# TRAJECTORIES_DIR=/data/trajectories
